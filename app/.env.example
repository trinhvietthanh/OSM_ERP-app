# Postgres connection (consumed by src/infrastructure/postgres/settings.py).
# Copy this file to .env and adjust for your environment.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=app

# Connection pool
POSTGRES_POOL_SIZE=10
POSTGRES_MAX_OVERFLOW=20
POSTGRES_ECHO=false

# JWT signing (consumed by src/modules/authenticate/infrastructure/settings.py).
# REQUIRED in production: set a strong random secret, e.g.
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=dev-secret-change-me
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_MINUTES=60
