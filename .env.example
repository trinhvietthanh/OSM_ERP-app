# Monorepo docker-compose overrides (optional).
# Copy to .env at the repo root to change the values interpolated into
# docker-compose.yml and passed to the containers. Defaults (shown) live in
# docker-compose.yml, so this file only needs the keys you want to override.
#
#   cp .env.example .env

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=app
