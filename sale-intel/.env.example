# Postgres (separate database on the shared container)
SALEINTEL_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/sale_intel

# Object storage: "local" (filesystem) or "s3" (MinIO / S3-compatible)
SALEINTEL_STORAGE_BACKEND=local
SALEINTEL_STORAGE_LOCAL_ROOT=./data/raw

# Only needed when SALEINTEL_STORAGE_BACKEND=s3
SALEINTEL_S3_ENDPOINT_URL=http://localhost:9000
SALEINTEL_S3_BUCKET=sale-intel-raw
SALEINTEL_S3_ACCESS_KEY=minioadmin
SALEINTEL_S3_SECRET_KEY=minioadmin

# Crawling politeness
SALEINTEL_HTTP_TIMEOUT_SECONDS=30
SALEINTEL_MIN_DELAY_SECONDS=2.0
SALEINTEL_USER_AGENT=SaleIntelBot/0.1 (+contact: ops@example.com; respectful crawler, no auth/captcha bypass)

# Deal detection
SALEINTEL_PRICE_DROP_THRESHOLD_PCT=10
